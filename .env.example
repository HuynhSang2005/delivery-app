# Environment Configuration Template
# Copy this file to .env.local and fill in actual values for local development
# Never commit .env or .env.local - they contain secrets

# Context7 API Key - for oh-my-opencode integration and documentation queries
CONTEXT7_API_KEY=ctx7sk-04e29f14-aa31-41e2-b375-a79619e74461

# Claude-mem web UI port - persistent memory across sessions
CLAUDE_MEM_PORT=37777

# Database Connection String
DATABASE_URL=postgresql://user:password@localhost:5432/delivery_db

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-here

# API Configuration
API_PORT=3001
API_HOST=localhost

# Next.js Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Node Environment
NODE_ENV=development
