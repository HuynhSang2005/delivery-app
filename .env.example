### App Runtime
NODE_ENV=development
API_PORT=3000
API_BASE_URL=http://localhost:3000/api/v1
ADMIN_BASE_URL=http://localhost:3001
JWT_SECRET=replace_with_local_secret

### Database
POSTGRES_IMAGE_TAG=16-3.4
POSTGRES_DB=delivery_app
POSTGRES_USER=delivery_user
POSTGRES_PASSWORD=delivery_pass
POSTGRES_PORT=5432
DATABASE_URL=postgresql://delivery_user:delivery_pass@localhost:5432/delivery_app?schema=public

### Redis (optional, enabled by compose profile)
REDIS_IMAGE_TAG=7-alpine
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction

### Debug Profile (redis-commander)
REDIS_COMMANDER_PORT=8081
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin

### Jobs Profile
DB_BACKUP_FILE=delivery_app_backup.sql
