{
  "name": "delivery-app-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "prepare": "husky",
    "nx": "nx",
    "graph": "nx graph",
    "show:projects": "nx show projects",
    "affected": "NX_INTERACTIVE=false nx affected -t lint typecheck test build --exclude=react-hook-form-zod-example,@expo/cicd-workflows-skill,pretty-mermaid-skill",
    "affected:e2e": "NX_INTERACTIVE=false nx affected -t e2e --exclude=react-hook-form-zod-example,@expo/cicd-workflows-skill,pretty-mermaid-skill",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:up:redis": "docker compose -f infra/docker-compose.yml --profile redis up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File infra/scripts/db-migrate.ps1",
    "db:seed": "powershell -ExecutionPolicy Bypass -File infra/scripts/db-seed.ps1",
    "db:smoke": "powershell -ExecutionPolicy Bypass -File infra/scripts/db-smoke.ps1",
    "db:reset": "powershell -ExecutionPolicy Bypass -File infra/scripts/db-reset.ps1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nx": "21.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "nx affected -t lint typecheck test --exclude=react-hook-form-zod-example,@expo/cicd-workflows-skill,pretty-mermaid-skill --files"
    ]
  }
}
