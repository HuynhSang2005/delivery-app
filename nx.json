{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": ["nx/plugins/package-json"],
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.*",
      "!{projectRoot}/**/*.test.*",
      "!{projectRoot}/test/**/*",
      "!{projectRoot}/**/*.md"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["default", "^default"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["default", "^default"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["default", "^default"],
      "cache": true
    }
  }
}
