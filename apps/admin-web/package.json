{
  "name": "admin-web",
  "version": "0.1.0",
  "private": true,
  "nx": {
    "tags": [
      "scope:admin",
      "type:app",
      "platform:web"
    ]
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NODE_ENV=production next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test tests/unit/**/*.unit.test.ts",
    "test:integration": "bun test tests/integration/**/*.integration.test.ts",
    "e2e:preflight": "NODE_ENV=production bun run build && bun test --timeout 120000 tests/e2e/runtime-smoke.e2e.test.ts",
    "test:e2e": "bun run e2e:preflight && playwright test",
    "e2e": "bun run test:e2e"
  },
  "dependencies": {
    "api-client": "workspace:*",
    "shared-kernel": "workspace:*",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "6.0.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
