{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile",
  "projectType": "application",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --cwd apps/mobile start"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --cwd apps/mobile build"
      },
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --cwd apps/mobile lint"
      },
      "cache": true,
      "dependsOn": [
        "^lint"
      ],
      "inputs": [
        "default",
        "^default"
      ]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --cwd apps/mobile typecheck"
      },
      "cache": true,
      "dependsOn": [
        "^typecheck"
      ],
      "inputs": [
        "default",
        "^default"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --cwd apps/mobile test"
      },
      "cache": true,
      "dependsOn": [
        "^test"
      ],
      "inputs": [
        "default",
        "^default"
      ]
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --cwd apps/mobile e2e"
      }
    }
  }
}
